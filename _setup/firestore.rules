rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Profil et présets : uniquement leur propriétaire
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Soirées : lecture pour tout compte connecté (nécessaire pour rejoindre par code).
    // ÉCRITURE réservée aux MC de la soirée — sauf l'acte de REJOINDRE
    // (seul changement autorisé : s'ajouter soi-même à la liste des MC).
    match /soirees/{id} {
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.mcUids;
      allow read: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.mcUids
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['mcUids'])
          && request.resource.data.mcUids.hasAll(resource.data.mcUids)
          && request.resource.data.mcUids.size() == resource.data.mcUids.size() + 1
          && request.auth.uid in request.resource.data.mcUids
        )
      );
      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // Registre des habitués : partagé entre les MC d'une même troupe
    match /registres/{uid} {
      allow read, write: if request.auth != null;
    }

    // Sons personnalisés (envoyés depuis l'app, par compte créateur)
    match /sons/{docId} {
      allow read, write: if request.auth != null;
    }

    // Médias (grandes images stockées hors de la fiche soirée, un doc par image)
    match /medias/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
